# ── Database ───────────────────────────────────────────────────────────────
PRISMRAG_DB_DSN=postgresql://prismrag:prismrag@localhost:5432/prismrag

# ── Gemini (Google AI) ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
PRISMRAG_EMBED_MODEL=gemini-embedding-001

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_random_64_char_string

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — Insight PrismRAG SaaS only (metadata billing_group=prismrag_saas)
# Provision: python scripts/setup_stripe_products.py --write-env
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Azure Storage (large-file uploads via SAS URL) ─────────────────────────
AZURE_STORAGE_ACCOUNT=prismragstorage
AZURE_STORAGE_KEY=your_storage_account_key_here
AZURE_STORAGE_CONTAINER=uploads

# ── Azure Service Bus (async worker queue) ──────────────────────────────────
# Get from: az servicebus namespace authorization-rule keys list ...
AZURE_SERVICE_BUS_CONN_STR=Endpoint=sb://prismrag-bus.servicebus.windows.net/;SharedAccessKeyName=...
AZURE_SERVICE_BUS_QUEUE=prismrag-jobs

# ── Redis (Phase 3 — rate limiting + monthly counters) ─────────────────────
# Phase 1+2: leave blank — in-process TTL cache used as fallback
REDIS_URL=
# Phase 3 (Azure Cache for Redis):
# REDIS_URL=rediss://:your_access_key@prismrag-cache.redis.cache.windows.net:6380

# ── App ────────────────────────────────────────────────────────────────────
PRISMRAG_ENV=development   # development | production
PRISMRAG_PORT=8001

# ── QA / Testing ────────────────────────────────────────────────────────────
# Local API tests (against locally-seeded PostgreSQL)
PRISMRAG_TEST_URL=http://localhost:8001
PRISMRAG_TEST_EMAIL=qa-local@test.prismrag.io
PRISMRAG_TEST_PASSWORD=QaTestPass!123
# Set QA_SEEDED=1 to use fixed tenant IDs from seed_qa_data.py (skips API tenant creation)
QA_SEEDED=1

# Prod Azure tests (separate credentials — seed with tests/seed_qa_data.py --production)
PRISMRAG_PROD_URL=https://prismrag.insightits.com
PRISMRAG_PROD_QA_EMAIL=qa-prod@insightits.com
PRISMRAG_PROD_QA_PASSWORD=QaProdPass!2026#
# PRISMRAG_AZURE_DB_DSN=postgresql://...@psql-insight-hospital-prod.../prismrag?sslmode=require

# ── Async processing (recommended) ─────────────────────────────────────────
PRISMRAG_USE_JOB_QUEUE=true

# ── Azure Communication Services Email (PrismRAG@insightits.com) ───────────
# See DOC/azure-email-aws-dns.md — domain DNS stays in AWS Route 53
AZURE_COMMUNICATION_CONNECTION_STRING=
PRISMRAG_EMAIL_FROM=PrismRAG@insightits.com
PRISMRAG_EMAIL_ENABLED=true

# ── Logging & alerts (cheap alternative to Log Analytics) ───────────────────
# Production: WARNING level + blob files (~$0.02/GB) instead of Log Analytics (~$2.76/GB)
PRISMRAG_LOG_LEVEL=INFO
PRISMRAG_LOG_BLOB_ENABLED=false
PRISMRAG_LOG_BLOB_CONTAINER=prismrag-logs
PRISMRAG_LOG_BLOB_FLUSH_SEC=300
# Reuse storage account (same as large-file uploads) or set connection string:
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# Error/critical alerts emailed here (comma-separated — use your personal email):
PRISMRAG_ADMIN_EMAILS=prismrag@insightits.com
PRISMRAG_ALERT_MIN_SEVERITY=ERROR

# ── CMEK (enterprise) ─────────────────────────────────────────────────────
PRISMRAG_CMEK_ENABLED=false

# ── LinkedIn API ────────────────────────────────────────────────────────────
# Create app: https://www.linkedin.com/developers/apps/new
# Add redirect URI: http://localhost:8080/callback
# Request products: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
