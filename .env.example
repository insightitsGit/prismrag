# ── Database ───────────────────────────────────────────────────────────────
PRISMRAG_DB_DSN=postgresql://user:password@localhost:5432/prismrag

# ── Gemini (Google AI) ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_random_64_char_string

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe dashboard (Products → Prices)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── App ────────────────────────────────────────────────────────────────────
PRISMRAG_ENV=development   # development | production
PRISMRAG_PORT=8001
